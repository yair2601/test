# ===================================================
# AI Auto Marketing Platform — Local Setup
# ===================================================
# Copy this file to .env.local and fill in real values
# Run: cp .env.local.example .env.local
# ===================================================

# --- PostgreSQL Database ---
# Option A: Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_marketing
# Option B: Neon (recommended for dev — free tier)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/ai_marketing?sslmode=require

DATABASE_URL=

# --- NextAuth ---
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- AI Provider ---
# Set to 'claude' or 'openai'
AI_PROVIDER=claude

# Anthropic (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI (required if AI_PROVIDER=openai)
# OPENAI_API_KEY=
